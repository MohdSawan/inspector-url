# DNS, WHOIS, ip geo, crt.sh, VT, Shodan
# ------------------------------
def dns_lookup(domain: str) -> Dict:
    resolver = dns.resolver.Resolver()
    out = {"A": [], "AAAA": [], "MX": [], "NS": [], "TXT": []}
    try:
        for r in resolver.resolve(domain, "A", lifetime=5):
            out["A"].append(r.to_text())
    except Exception:
        pass
    try:
        for r in resolver.resolve(domain, "AAAA", lifetime=5):
            out["AAAA"].append(r.to_text())
    except Exception:
        pass
    try:
        for r in resolver.resolve(domain, "MX", lifetime=5):
            out["MX"].append(r.to_text())
    except Exception:
        pass
    try:
        for r in resolver.resolve(domain, "NS", lifetime=5):
            out["NS"].append(r.to_text())
    except Exception:
        pass
    try:
        for r in resolver.resolve(domain, "TXT", lifetime=5):
            # r.strings may be bytes
            vals = []
            for s in r.strings:
                vals.append(s.decode() if isinstance(s, bytes) else str(s))
            out["TXT"].append(" ".join(vals))
    except Exception:
        pass
    return out

def do_whois(domain: str) -> Dict:
    try:
        w = pywhois.whois(domain)
        raw = str(getattr(w, "text", "") or "")
        registrar = getattr(w, "registrar", None)
        creation = getattr(w, "creation_date", None)
        expiration = getattr(w, "expiration_date", None)
        emails = getattr(w, "emails", None) or []
        if isinstance(emails, str):
            emails = [emails]
        return {"raw": raw, "registrar": registrar, "creation": str(creation), "expiration": str(expiration), "emails": emails}
    except Exception:
        return {"raw": None, "registrar": None, "creation": None, "expiration": None, "emails": []}

def ip_geolocation(ip: str) -> Optional[Dict]:
    try:
        r = requests.get(f"http://ip-api.com/json/{ip}?fields=status,country,regionName,city,isp,org,as,query", timeout=6, headers={"User-Agent": USER_AGENT})
        if r.status_code == 200:
            j = r.json()
            if j.get("status") == "success":
                return j
    except Exception:
        pass
    return None

def crtsh_lookup(domain: str, timeout: int = 8) -> Optional[List[Dict]]:
    try:
        url = f"https://crt.sh/?q=%25{domain}&output=json"
        r = requests.get(url, timeout=timeout, headers={"User-Agent": USER_AGENT})
        if r.status_code == 200:
            try:
                return r.json()
            except Exception:
                return None
    except Exception:
        pass
    return None

def virustotal_domain_lookup(domain: str, api_key: str, timeout: int = 8) -> Optional[Dict]:
    if not api_key:
        return None
    try:
        headers = {"x-apikey": api_key}
        # Use VT v3 domain/report-like endpoints: domain reports require API specifics; we'll hit /domains/{domain}
        url = f"https://www.virustotal.com/api/v3/domains/{domain}"
        r = requests.get(url, headers=headers, timeout=timeout)
        if r.status_code == 200:
            return r.json()
    except Exception:
        pass
    return None

def shodan_host_lookup(ip: str, api_key: str, timeout: int = 8) -> Optional[Dict]:
    if not api_key:
        return None
    try:
        url = f"https://api.shodan.io/shodan/host/{ip}?key={api_key}"
        r = requests.get(url, timeout=timeout)
        if r.status_code == 200:
            return r.json()
    except Exception:
        pass
    return None

# ------------------------------
# Link checking (concurrent)
# ------------------------------
def check_links(links: List[str], concurrency: int = 10, timeout: int = 6) -> Dict[str, Dict]:
    results = {}
    # normalize relative URLs by skipping them (or we could join to base)
    to_check = [l for l in links if l.startswith("http://") or l.startswith("https://") or l.startswith("//")]
    # normalize // to http://
    to_check = [("http:" + l) if l.startswith("//") else l for l in to_check]
    if not to_check:
        return results
    with concurrent.futures.ThreadPoolExecutor(max_workers=concurrency) as ex:
        futures = {ex.submit(head_request, l, timeout): l for l in to_check}
        for fut in concurrent.futures.as_completed(futures):
            l = futures[fut]
            try:
                url, status, ctype = fut.result()
                results[l] = {"status": status, "content_type": ctype}
            except Exception as e:
                results[l] = {"status": None, "error": str(e)}
    return results

# ------------------------------
# Screenshot (optional: Playwright)
# ------------------------------
def take_screenshot(url: str, out_path: str = "screenshot.png", timeout: int = 15) -> Optional[str]:
    try:
        from playwright.sync_api import sync_playwright
    except Exception:
        return None
    try:
        with sync_playwright() as p:
            browser = p.chromium.launch(headless=True)
            page = browser.new_page(viewport={"width": 1280, "height": 800}, user_agent=USER_AGENT)
            page.goto(url, wait_until="networkidle", timeout=timeout * 1000)
            page.screenshot(path=out_path, full_page=True)
            browser.close()
        return out_path
    except Exception:
        return None

# ------------------------------
# Database history (SQLite)
# ------------------------------
def init_db(db_file: str = DB_FILE):
    conn = sqlite3.connect(db_file)
    cur = conn.cursor()
    cur.execute("""
    CREATE TABLE IF NOT EXISTS scans (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        target TEXT,
        timestamp TEXT,
        report_json TEXT
    )
    """)
    conn.commit()
    conn.close()

def save_scan_to_db(target: str, report: dict, db_file: str = DB_FILE):
    init_db(db_file)
    conn = sqlite3.connect(db_file)
    cur = conn.cursor()
    cur.execute("INSERT INTO scans (target, timestamp, report_json) VALUES (?, ?, ?)", (target, datetime.utcnow().isoformat(), json.dumps(report)))
    conn.commit()
    conn.close()

def get_history(target: str, db_file: str = DB_FILE, limit: int = 20) -> List[Dict]:
    if not os.path.exists(db_file):
        return []
    conn = sqlite3.connect(db_file)
    cur = conn.cursor()
    cur.execute("SELECT id, timestamp, report_json FROM scans WHERE target = ? ORDER BY id DESC LIMIT ?", (target, limit))
    rows = cur.fetchall()
    out = []
    for r in rows:
        out.append({"id": r[0], "timestamp": r[1], "report": json.loads(r[2])})
    conn.close()
    return out

# ------------------------------
# Suggestions & heuristics
# ------------------------------
def generate_suggestions(report: Dict) -> List[str]:
    s = []
    headers = {k.lower(): v for k, v in (report.get("http", {}).get("headers") or {}).items()}
    security_headers = report.get("security_headers", {})
    # Security headers missing
    missing = [h for h in COMMON_SECURITY_HEADERS if not security_headers.get(h)]
    if missing:
        s.append(f"Missing common security headers: {', '.join(missing)}.")
    # CSP issues
    csp = security_headers.get("content-security-policy")
    csp_issues = evaluate_csp(csp)
    s.extend(csp_issues)
    # Cookies
    cookies = security_headers.get("cookie_flags") or []
    for c in cookies:
        if not c.get("secure"):
            s.append(f"Cookie not Secure: {c.get('cookie')}")
        if not c.get("httponly"):
            s.append(f"Cookie not HttpOnly: {c.get('cookie')}")
    # TLS expiry
    cert = report.get("cert")
    if cert and cert.get("not_after"):
        try:
            na = datetime.fromisoformat(cert["not_after"])
            days_left = (na - datetime.utcnow()).days
            if days_left < 30:
                s.append(f"TLS certificate expires in ~{days_left} days; renew soon.")
        except Exception:
            pass
    else:
        if report.get("http", {}).get("final_url", "").startswith("https"):
            s.append("Unable to obtain TLS certificate details.")
    # robots / sitemap
    if not report.get("http", {}).get("robots_txt"):
        s.append("No robots.txt at root; consider adding to control crawlers.")
    if not report.get("http", {}).get("sitemap_xml"):
        s.append("No sitemap.xml at root; consider adding for SEO.")
    # link issues
    broken = []
    for u, res in (report.get("link_checks") or {}).items():
        if res.get("status") is None or (res.get("status") and res["status"] >= 400):
            broken.append(f"{u} -> {res.get('status')}")
    if broken:
        s.append(f"Broken/outgoing link issues found: {len(broken)} examples: {broken[:5]}")
    # framework suggestions
    fps = report.get("fingerprints") or []
    if "wordpress" in fps:
        s.append("Site appears to be WordPress — ensure plugins/themes are up-to-date and remove unused plugins.")
    if report.get("open_ports"):
        open_ports = [p for p, val in (report.get("open_ports") or {}).items() if val]
        if open_ports:
            s.append(f"Open ports detected: {', '.join(open_ports)}; verify they're intended and access-controlled.")
    # default
    if report.get("http", {}).get("status_code", 0) and 200 <= report["http"]["status_code"] < 300:
        s.append("Site returns 2xx — baseline reachable.")
    else:
        s.append("Site returned non-2xx status or unreachable; check server configuration and redirects.")
    return s

# ------------------------------
# Main inspection orchestration
# ------------------------------
def inspect_target(target: str, deep: bool = False, check_links_flag: bool = False, concurrency: int = 10,
                   link_timeout: int = 6, vt_api_key: Optional[str] = None, shodan_key: Optional[str] = None,
                   crtsh_flag: bool = False, screenshot_flag: bool = False, screenshot_out: str = "screenshot.png",
                   ports: List[int] = [80, 443], timeout: int = 8, save_db: bool = False) -> Dict:
    checked_at = datetime.utcnow().isoformat()
    url = normalize_url(target)
    http_resp, html = http_get(url, timeout=timeout)
    http_info = {}
    if http_resp:
        http_info = {
            "url": target,
            "final_url": http_resp.url,
            "status_code": http_resp.status_code,
            "headers": dict(http_resp.headers),
        }
        if html:
            parsed = parse_html_and_links(html, http_resp.url)
            http_info.update(parsed)
        else:
            http_info.update({"title": None, "meta_description": None, "links": [], "scripts": [], "internal_links_sample": [], "external_links_sample": [], "num_links": 0})
        # robots/sitemap
        try:
            parsed_u = requests.utils.urlparse(http_resp.url)
            base = f"{parsed_u.scheme}://{parsed_u.netloc}"
            r = requests.get(base + "/robots.txt", headers={"User-Agent": USER_AGENT}, timeout=4)
            http_info["robots_txt"] = r.text[:20000] if r.status_code == 200 else None
        except Exception:
            http_info["robots_txt"] = None
        try:
            s = requests.get(base + "/sitemap.xml", headers={"User-Agent": USER_AGENT}, timeout=4)
            http_info["sitemap_xml"] = s.text[:20000] if s.status_code == 200 and "xml" in (s.headers.get("Content-Type") or "") else None
        except Exception:
            http_info["sitemap_xml"] = None
    else:
        http_info = {"url": target, "final_url": None, "status_code": None, "headers": {}, "title": None, "meta_description": None, "links": [], "scripts": [], "num_links": 0, "robots_txt": None, "sitemap_xml": None}

    # Domain / DNS / IP
    extracted = tldextract.extract(url)
    domain = extracted.registered_domain or (extracted.domain + "." + extracted.suffix)
    dns_info = dns_lookup(domain)
    ip = None
    if dns_info.get("A"):
        ip = dns_info["A"][0]
    else:
        try:
            host = requests.utils.urlparse(http_info.get("final_url") or url).hostname
            ip = socket.gethostbyname(host)
        except Exception:
            ip = None

    cert = None
    if http_info.get("final_url") and http_info.get("final_url").startswith("https"):
        host_for_cert = requests.utils.urlparse(http_info.get("final_url")).hostname
        cert = get_cert_info(host_for_cert, 443, timeout=timeout)

    # TLS versions
    tls_versions = {}
    if ip and http_info.get("final_url", "").startswith("https"):
        host_for_tls = requests.utils.urlparse(http_info.get("final_url")).hostname
        tls_versions = test_tls_versions(host_for_tls)

    # fingerprints
    fps = fingerprint_frameworks(http_info.get("headers", {}), html, http_info.get("final_url") or url)

    # optional deep lookups
    whois_info = None
    geo = None
    open_ports = None
    vt_info = None
    shodan_info = None
    crtsh_info = None
    if deep:
        whois_info = do_whois(domain)
        if ip:
            geo = ip_geolocation(ip)
            # quick port check
            open_ports = {}
            for p in ports:
                s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                s.settimeout(1.2)
                try:
                    s.connect((ip, p))
                    open_ports[str(p)] = True
                except Exception:
                    open_ports[str(p)] = False
                finally:
                    s.close()
        if vt_api_key:
            vt_info = virustotal_domain_lookup(domain, vt_api_key)
        if shodan_key and ip:
            shodan_info = shodan_host_lookup(ip, shodan_key)
        if crtsh_flag:
            crtsh_info = crtsh_lookup(domain)

    # link checks
    link_checks = None
    if check_links_flag:
        all_links = list(set(http_info.get("links", []) + http_info.get("external_links_sample", [])))
        link_checks = check_links(all_links, concurrency=concurrency, timeout=link_timeout)

    security_headers = check_security_headers(http_info.get("headers", {}))

    report = {
        "target": target,
        "checked_at": checked_at,
        "http": http_info,
        "cert": cert,
        "tls_versions": tls_versions,
        "dns": dns_info,
        "ip": ip,
        "geo": geo,
        "whois": whois_info,
        "open_ports": open_ports,
        "fingerprints": fps,
        "security_headers": security_headers,
        "link_checks": link_checks,
        "vt": vt_info,
        "shodan": shodan_info,
        "crtsh": crtsh_info,
    }

    report["suggestions"] = generate_suggestions(report)

    # screenshot
    screenshot_path = None
    if screenshot_flag:
        sp = take_screenshot(http_info.get("final_url") or url, out_path=screenshot_out)
        report["screenshot"] = sp

    # Save to DB if requested
    if save_db:
        try:
            save_scan_to_db(target, report)
        except Exception:
            pass

    return report

# ------------------------------
# Printing helpers
# ------------------------------
def print_pretty(report: Dict):
    print("=" * 96)
    print(f"Target: {report.get('target')}")
    print(f"Checked at (UTC): {report.get('checked_at')}")
    print("-" * 96)
    http = report.get("http", {})
    print(f"Final URL: {http.get('final_url')}")
    print(f"Status: {http.get('status_code')}")
    print(f"Title: {http.get('title')}")
    print(f"Meta description: {http.get('meta_description')}")
    print(f"Links found: {http.get('num_links')}")
    print("-" * 96)
    print("Security headers:")
    for k, v in (report.get("security_headers") or {}).items():
        if k == "cookie_flags":
            continue
        print(f"  {k}: {v}")
    print("Cookie flags:")
    for c in (report.get("security_headers") or {}).get("cookie_flags") or []:
        print(f"  {c}")
    print("-" * 96)
    print("TLS / cert:")
    if report.get("cert"):
        c = report["cert"]
        print(f"  Subject: {c.get('subject')}")
        print(f"  Issuer: {c.get('issuer')}")
        print(f"  Valid: {c.get('not_before')} -> {c.get('not_after')}")
        print(f"  SANs: {c.get('san')}")
    print(f"  TLS versions supported: {report.get('tls_versions')}")
    print("-" * 96)
    print("DNS records:")
    for k, v in (report.get("dns") or {}).items():
        print(f"  {k}: {v}")
    print(f"Resolved IP: {report.get('ip')}")
    if report.get("geo"):
        print(f"Geo: {report.get('geo')}")
    print("-" * 96)
    if report.get("fingerprints"):
        print("Fingerprints / frameworks: " + ", ".join(report.get("fingerprints")))
    if report.get("open_ports"):
        print("Open ports (deep):")
        for p, v in report["open_ports"].items():
            print(f"  {p}: {'open' if v else 'closed'}")
    if report.get("link_checks"):
        total = len(report["link_checks"])
        bad = sum(1 for v in report["link_checks"].values() if (v.get("status") is None or (isinstance(v.get("status"), int) and v["status"] >= 400)))
        print(f"Link checks: {total} links checked, {bad} problematic")
    print("-" * 96)
    print("Suggestions:")
    for s in report.get("suggestions", []):
        print(" - " + s)
    print("=" * 96)

# ------------------------------
# CLI
# ------------------------------
def parse_args():
    p = argparse.ArgumentParser(description="Enhanced URL inspector (recon + security hints + optional integrations)")
    p.add_argument("target", help="URL or domain to inspect")
    p.add_argument("--deep", action="store_true", help="Enable WHOIS, geo, open ports, and optional VT/Shodan/crtsh lookups")
    p.add_argument("--check-links", action="store_true", help="Check external links found on page")
    p.add_argument("--concurrency", type=int, default=10, help="Concurrency for link checks")
    p.add_argument("--link-timeout", type=int, default=6, help="Timeout for link HEAD requests")
    p.add_argument("--vt-api-key", default=os.environ.get("VT_API_KEY"), help="VirusTotal API key (optional)")
    p.add_argument("--shodan-key", default=os.environ.get("SHODAN_KEY"), help="Shodan API key (optional)")
    p.add_argument("--crtsh", action="store_true", help="Query crt.sh for certificate transparency entries (no key required)")
    p.add_argument("--screenshot", action="store_true", help="Take a screenshot of the page (Playwright required)")
    p.add_argument("--screenshot-out", default="screenshot.png", help="Screenshot output path")
    p.add_argument("--ports", default="80,443", help="Comma-separated ports for quick port checks during deep scan")
    p.add_argument("--timeout", type=int, default=8, help="HTTP timeout")
    p.add_argument("--pretty", action="store_true", help="Print human-friendly summary in addition to JSON")
    p.add_argument("--save-db", action="store_true", help="Save scan report to local sqlite database")
    p.add_argument("--check-crtsh-only", action="store_true", help="Only run crt.sh lookup and exit (helper)")
    return p.parse_args()

def main(argv=None):
    args = parse_args()
    ports = [int(p.strip()) for p in args.ports.split(",") if p.strip().isdigit()]
    try:
        if args.check_crtsh_only:
            extracted = tldextract.extract(args.target)
            domain = extracted.registered_domain or (extracted.domain + "." + extracted.suffix)
            res = crtsh_lookup(domain)
            print(json.dumps(res or [], indent=2, ensure_ascii=False))
            return
        report = inspect_target(args.target, deep=args.deep, check_links_flag=args.check_links, concurrency=args.concurrency,
                                link_timeout=args.link_timeout, vt_api_key=args.vt_api_key, shodan_key=args.shodan_key,
                                crtsh_flag=args.crtsh, screenshot_flag=args.screenshot, screenshot_out=args.screenshot_out,
                                ports=ports, timeout=args.timeout, save_db=args.save_db)
    except Exception:
        print("Error during inspection:", file=sys.stderr)
        traceback.print_exc()
        sys.exit(1)
    if args.pretty:
        print_pretty(report)
    print(json.dumps(report, indent=2, ensure_ascii=False))
    if args.save_db:
        print(f"Wrote scan to {DB_FILE}", file=sys.stderr)

if __name__ == "__main__":
    main()
