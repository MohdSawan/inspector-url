# ------------------------------
# Utilities
# ------------------------------
def normalize_url(u: str) -> str:
    u = u.strip()
    if not u:
        raise ValueError("Empty URL")
    if not re.match(r"^https?://", u, re.I):
        u = "http://" + u
    return u

def http_get(url: str, timeout: int = 8) -> Tuple[Optional[requests.Response], Optional[str]]:
    headers = {"User-Agent": USER_AGENT}
    try:
        r = requests.get(url, headers=headers, timeout=timeout, allow_redirects=True)
        text = None
        ctype = r.headers.get("Content-Type", "")
        if r.status_code == 200 and "text/html" in ctype:
            text = r.text
        return r, text
    except Exception as e:
        return None, None

def head_request(url: str, timeout: int = 6) -> Tuple[str, Optional[int], Optional[str]]:
    headers = {"User-Agent": USER_AGENT}
    try:
        r = requests.head(url, headers=headers, timeout=timeout, allow_redirects=True)
        return url, r.status_code, r.headers.get("Content-Type")
    except Exception:
        # fallback to GET
        try:
            r = requests.get(url, headers=headers, timeout=timeout, stream=True)
            return url, r.status_code, r.headers.get("Content-Type")
        except Exception:
            return url, None, None

# ------------------------------
# HTML parsing & fingerprinting
# ------------------------------
def parse_html_and_links(html: str, base_url: str) -> Dict:
    soup = BeautifulSoup(html, "html.parser")
    title = soup.title.string.strip() if soup.title and soup.title.string else None
    meta_desc = None
    m = soup.find("meta", attrs={"name": re.compile(r"^description$", re.I)})
    if m and m.get("content"):
        meta_desc = m["content"].strip()
    # generator meta often shows CMS
    meta_gen = None
    mg = soup.find("meta", attrs={"name": re.compile(r"generator", re.I)})
    if mg and mg.get("content"):
        meta_gen = mg["content"].strip()
    links = []
    for a in soup.find_all("a", href=True):
        links.append(a["href"].strip())
    scripts = [s.get("src") for s in soup.find_all("script", src=True)]
    link_objs = classify_links(links, base_url)
    return {
        "title": title,
        "meta_description": meta_desc,
        "meta_generator": meta_gen,
        "links": links,
        "scripts": [s for s in scripts if s],
        "internal_links_sample": link_objs["internal"][:8],
        "external_links_sample": link_objs["external"][:8],
        "num_links": len(link_objs["internal"]) + len(link_objs["external"]),
    }

def classify_links(links: List[str], base_url: str) -> Dict[str, List[str]]:
    extracted = tldextract.extract(base_url)
    base_domain = extracted.registered_domain
    internal = []
    external = []
    for href in links:
        if href.startswith("#") or href.startswith("mailto:") or href.startswith("javascript:"):
            continue
        if href.startswith("//"):
            href_full = "http:" + href
        elif href.startswith("http://") or href.startswith("https://"):
            href_full = href
        else:
            href_full = href
        ext = tldextract.extract(href_full)
        if ext.registered_domain and base_domain and ext.registered_domain != base_domain:
            external.append(href_full)
        else:
            internal.append(href_full)
    return {"internal": internal, "external": external}

# Simple fingerprinting heuristics for common CMS/frameworks
def fingerprint_frameworks(headers: Dict[str, str], html: Optional[str], url: str) -> List[str]:
    tags = []
    # headers
    server = headers.get("Server") or headers.get("server") or ""
    if "nginx" in server.lower():
        tags.append("nginx")
    if "cloudflare" in server.lower():
        tags.append("cloudflare")
    if "apache" in server.lower():
        tags.append("apache")
    # html heuristics
    h = (html or "").lower()
    if "wp-content" in h or "wp-emoji-release.min.js" in h or "wordpress" in h:
        tags.append("wordpress")
    if "drupal" in h or "/sites/default/" in h:
        tags.append("drupal")
    if "joomla" in h or "joomla" in h:
        tags.append("joomla")
    if "next-data" in h or "_next" in h:
        tags.append("next.js")
    if "react" in h or "data-reactroot" in h:
        tags.append("react")
    if "angular" in h or "ng-app" in h:
        tags.append("angular")
    # common filenames
    try:
        parsed = requests.utils.urlparse(url)
        base = f"{parsed.scheme}://{parsed.netloc}"
        # quick path checks (not blocking)
        robots = requests.get(base + "/robots.txt", headers={"User-Agent": USER_AGENT}, timeout=4)
        if robots.status_code == 200 and "wp-content" in robots.text:
            tags.append("wordpress")
    except Exception:
        pass
    return sorted(set(tags))

# ------------------------------
# Security header & cookie analysis
# ------------------------------
def check_security_headers(headers: Dict[str, str]) -> Dict[str, Optional[str]]:
    found = {}
    lheaders = {k.lower(): v for k, v in headers.items()}
    for h in COMMON_SECURITY_HEADERS:
        found[h] = lheaders.get(h)
    # cookies: might be multiple Set-Cookie headers
    sc = []
    for k, v in headers.items():
        if k.lower() == "set-cookie":
            sc.append(v)
    # requests may merge multiple Set-Cookie into a single header separated by commas (not ideal).
    found["set_cookie_raw"] = sc if sc else headers.get("Set-Cookie") or headers.get("set-cookie")
    found["cookie_flags"] = analyze_cookies(sc if sc else [])
    return found

def analyze_cookies(set_cookie_headers: List[str]) -> List[Dict]:
    out = []
    for val in set_cookie_headers:
        # split on ';' -> name=..., attributes
        parts = [p.strip() for p in val.split(";")]
        if not parts:
            continue
        name_pair = parts[0]
        attributes = {p.lower(): True for p in parts[1:]}
        secure = "secure" in attributes
        httponly = "httponly" in attributes
        samesite = None
        for a in parts[1:]:
            if a.strip().lower().startswith("samesite="):
                samesite = a.split("=", 1)[1]
        out.append({
            "cookie": name_pair,
            "secure": secure,
            "httponly": httponly,
            "samesite": samesite,
            "attrs": attributes,
        })
    return out

def evaluate_csp(csp_value: Optional[str]) -> List[str]:
    issues = []
    if not csp_value:
        return []
    v = csp_value.lower()
    if "'unsafe-inline'" in v or "unsafe-inline" in v:
        issues.append("CSP allows 'unsafe-inline' which weakens protections against XSS.")
    if "*" in v:
        issues.append("CSP contains wildcard '*' source which is permissive.")
    if "data:" in v:
        issues.append("CSP allows data: sources which can allow inline content.")
    return issues

# ------------------------------
# TLS probing
# ------------------------------
def get_cert_info(hostname: str, port: int = 443, timeout: int = 8) -> Optional[Dict]:
    try:
        ctx = ssl.create_default_context()
        with socket.create_connection((hostname, port), timeout=timeout) as sock:
            with ctx.wrap_socket(sock, server_hostname=hostname) as ssock:
                der = ssock.getpeercert(True)
                pem = ssl.DER_cert_to_PEM_cert(der)
        cert = x509.load_pem_x509_certificate(pem.encode(), default_backend())
        subj = {attr.oid._name: attr.value for attr in cert.subject}
        issuer = {attr.oid._name: attr.value for attr in cert.issuer}
        san = []
        try:
            ext = cert.extensions.get_extension_for_class(x509.SubjectAlternativeName)
            san = ext.value.get_values_for_type(x509.DNSName)
        except Exception:
            san = []
        return {
            "subject": subj,
            "issuer": issuer,
            "not_before": str(cert.not_valid_before),
            "not_after": str(cert.not_valid_after),
            "san": san,
            "serial_number": hex(cert.serial_number),
            "sig_alg": getattr(cert, "signature_algorithm_oid", None)._name if getattr(cert, "signature_algorithm_oid", None) else None,
        }
    except Exception:
        return None

# Test TLS protocol support (best-effort)
def test_tls_versions(hostname: str, port: int = 443, timeout: int = 4) -> Dict[str, bool]:
    versions = {}
    # Use ssl.TLSVersion if available (py3.7+)
    support_map = {
        "TLSv1": getattr(ssl, "PROTOCOL_TLSv1", None),
        "TLSv1_1": getattr(ssl, "PROTOCOL_TLSv1_1", None),
        "TLSv1_2": getattr(ssl, "PROTOCOL_TLSv1_2", None),
    }
    # TLSv1_3 not available via PROTOCOL_* constants; use minimum_version trick if possible
    for name, proto in support_map.items():
        if proto is None:
            versions[name] = False
            continue
        try:
            ctx = ssl.SSLContext(proto)
            ctx.set_ciphers("DEFAULT")
            with socket.create_connection((hostname, port), timeout=timeout) as sock:
                with ctx.wrap_socket(sock, server_hostname=hostname) as ssock:
                    versions[name] = True
        except Exception:
            versions[name] = False
    # Try TLS 1.3 via minimum_version if available
    try:
        ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_CLIENT)
        if hasattr(ssl, "TLSVersion"):
            ctx.minimum_version = ssl.TLSVersion.TLSv1_3
            ctx.maximum_version = ssl.TLSVersion.TLSv1_3
            try:
                with socket.create_connection((hostname, port), timeout=timeout) as sock:
                    with ctx.wrap_socket(sock, server_hostname=hostname) as ssock:
                        versions["TLSv1_3"] = True
            except Exception:
                versions["TLSv1_3"] = False
        else:
            versions["TLSv1_3"] = False
    except Exception:
        versions["TLSv1_3"] = False
    return versions

